{"ast":null,"code":"export const getDifficultyColor=difficulty=>{if(difficulty===\"Easy\")return\"easy\";if(difficulty===\"Medium\")return\"medium\";if(difficulty===\"Hard\")return\"hard\";return\"\";};export const calculateTopicProgress=(problems,topic)=>{const topicProblems=problems.filter(p=>p.topic===topic);const solved=topicProblems.filter(p=>p.solved).length;if(topicProblems.length===0)return 0;return Math.round(solved/topicProblems.length*100);};","map":{"version":3,"names":["getDifficultyColor","difficulty","calculateTopicProgress","problems","topic","topicProblems","filter","p","solved","length","Math","round"],"sources":["C:/Users/prati/pratik-dsa-sheet/src/utils/helpers.js"],"sourcesContent":["export const getDifficultyColor = (difficulty) => {\r\n  if (difficulty === \"Easy\") return \"easy\";\r\n  if (difficulty === \"Medium\") return \"medium\";\r\n  if (difficulty === \"Hard\") return \"hard\";\r\n  return \"\";\r\n};\r\n\r\nexport const calculateTopicProgress = (problems, topic) => {\r\n  const topicProblems = problems.filter((p) => p.topic === topic);\r\n  const solved = topicProblems.filter((p) => p.solved).length;\r\n  if (topicProblems.length === 0) return 0;\r\n  return Math.round((solved / topicProblems.length) * 100);\r\n};"],"mappings":"AAAA,MAAO,MAAM,CAAAA,kBAAkB,CAAIC,UAAU,EAAK,CAChD,GAAIA,UAAU,GAAK,MAAM,CAAE,MAAO,MAAM,CACxC,GAAIA,UAAU,GAAK,QAAQ,CAAE,MAAO,QAAQ,CAC5C,GAAIA,UAAU,GAAK,MAAM,CAAE,MAAO,MAAM,CACxC,MAAO,EAAE,CACX,CAAC,CAED,MAAO,MAAM,CAAAC,sBAAsB,CAAGA,CAACC,QAAQ,CAAEC,KAAK,GAAK,CACzD,KAAM,CAAAC,aAAa,CAAGF,QAAQ,CAACG,MAAM,CAAEC,CAAC,EAAKA,CAAC,CAACH,KAAK,GAAKA,KAAK,CAAC,CAC/D,KAAM,CAAAI,MAAM,CAAGH,aAAa,CAACC,MAAM,CAAEC,CAAC,EAAKA,CAAC,CAACC,MAAM,CAAC,CAACC,MAAM,CAC3D,GAAIJ,aAAa,CAACI,MAAM,GAAK,CAAC,CAAE,MAAO,EAAC,CACxC,MAAO,CAAAC,IAAI,CAACC,KAAK,CAAEH,MAAM,CAAGH,aAAa,CAACI,MAAM,CAAI,GAAG,CAAC,CAC1D,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}